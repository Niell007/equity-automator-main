# Application Configuration
VITE_APP_NAME=Equity Automator
VITE_APP_ENV=development
VITE_APP_DEBUG=true
VITE_APP_URL=http://localhost:5173

# API Configuration
VITE_API_URL=http://localhost:3005
VITE_API_KEY=your_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# Authentication Configuration
VITE_AUTH_SESSION_TIMEOUT=3600
VITE_AUTH_MAX_LOGIN_ATTEMPTS=5
VITE_AUTH_PASSWORD_MIN_LENGTH=8
VITE_AUTH_PASSWORD_EXPIRY_DAYS=90
VITE_AUTH_2FA_ENABLED=false
VITE_AUTH_2FA_TYPE=2fa_app

# Document Management
VITE_DOCUMENT_MAX_FILE_SIZE=10485760
VITE_DOCUMENT_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx
VITE_DOCUMENT_ENABLE_BULK_UPLOAD=true
VITE_DOCUMENT_ENABLE_VERSION_CONTROL=true
VITE_DOCUMENT_AUTO_DELETE_DAYS=30
VITE_DOCUMENT_ENCRYPTION_ENABLED=true

# Feature Flags
VITE_ENABLE_LIVE_CHAT=true
VITE_ENABLE_2FA=true
VITE_ENABLE_DOCUMENT_EXPORT=true

# Database Configuration (Server)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=equity_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Email Configuration (Server)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Equity Automator

# JWT Configuration (Server)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Redis Configuration (Server, Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Authentication Configuration
VITE_AUTH_API_URL=http://localhost:3005/auth
VITE_DOCUMENTS_API_URL=http://localhost:3005/documents
VITE_REPORTS_API_URL=http://localhost:3005/reports
VITE_SUPPORT_API_URL=http://localhost:3005/support
VITE_CHAT_API_URL=http://localhost:3005/chat

# Database Configuration
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=equity_db
VITE_DB_USER=your_db_user
VITE_DB_PASSWORD=your_db_password 